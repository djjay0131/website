---
import Base from "../../layouts/Base.astro";
import { loadContentPool } from "../../lib/cv-data";
import { mdToHtml } from "../../lib/md";
import path from "node:path";

const pool = loadContentPool(path.resolve("data/content"));
const projects = Object.values(pool.projects);
const base = import.meta.env.BASE_URL;
---

<Base title="Jason Cusati — Projects" description="Selected projects and research by Jason Cusati.">
  <h1>Selected Projects &amp; Research</h1>

  <div class="project-list">
    {projects.map((p) => (
      <article class="project-card">
        <h2><a href={`${base}projects/${p.id}`}>{p.name}</a></h2>
        <p set:html={mdToHtml(p.summary)} />
        {p.github && (
          <a href={p.github} target="_blank" rel="noopener noreferrer" class="github-link">
            View on GitHub
          </a>
        )}
      </article>
    ))}
  </div>
</Base>

<style>
  .project-list {
    display: grid;
    gap: 1.5rem;
  }

  .project-card {
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
  }

  .project-card h2 {
    font-size: 1.15rem;
    margin-top: 0;
    border-bottom: none;
  }

  .project-card p {
    color: var(--color-muted);
    margin: 0.5rem 0;
  }

  .github-link {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
  }
</style>
