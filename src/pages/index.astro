---
import Base from "../layouts/Base.astro";
import { loadContentPool } from "../lib/cv-data";
import path from "node:path";

const pool = loadContentPool(path.resolve("data/content"));
const meta = pool.meta;
const summary = Object.values(pool.summaries)[0];
const base = import.meta.env.BASE_URL;
---

<Base title="Jason Cusati">
  <div class="hero">
    {meta.include_photo && (
      <img
        src={`${base}photo_jason_1.jpeg`}
        alt={`Photo of ${meta.name}`}
        class="hero-photo"
      />
    )}
    <div class="hero-text">
      <h1>{meta.name}</h1>
      <p class="subtitle">{summary?.text}</p>
      <div class="hero-links">
        <a href={`mailto:${meta.contact.email}`}>{meta.contact.email}</a>
        {meta.contact.github && (
          <a href={`https://github.com/${meta.contact.github}`}>GitHub</a>
        )}
        {meta.contact.linkedin && (
          <a href={`https://linkedin.com/in/${meta.contact.linkedin}`}>LinkedIn</a>
        )}
      </div>
      <div class="hero-actions">
        <a href={`${base}cv/academic`} class="btn btn-primary">View CV</a>
        <a href={`${base}pdfs/academic.pdf`} class="btn btn-secondary">Download PDF</a>
        <a href={`${base}papers`} class="btn btn-secondary">Papers</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .hero {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding: 2rem 0;
  }

  .hero-photo {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .hero-text {
    flex: 1;
  }

  .subtitle {
    color: var(--color-muted);
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--color-primary);
    color: #fff;
  }

  .btn-primary:hover {
    background: #8e0530;
    text-decoration: none;
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-border);
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .hero {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .hero-links {
      justify-content: center;
    }

    .hero-actions {
      justify-content: center;
    }
  }
</style>
