---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Jason Cusati — Software Engineer, Researcher" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href={base} class="nav-brand">Jason Cusati</a>
        <div class="nav-links">
          <a href={`${base}cv/academic`}>CV</a>
          <a href={`${base}papers`}>Papers</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Jason Cusati</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #B6073F;
    --color-accent: #88AC0B;
    --color-text: #1a1a1a;
    --color-muted: #555;
    --color-bg: #fff;
    --color-surface: #f8f8f8;
    --color-border: #e0e0e0;
    --font-serif: 'Georgia', 'Times New Roman', serif;
    --font-sans: system-ui, -apple-system, 'Segoe UI', sans-serif;
    --font-mono: 'Menlo', 'Consolas', monospace;
    --max-width: 800px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
  }

  body {
    font-family: var(--font-serif);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    width: 100%;
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .site-header {
    border-bottom: 3px solid var(--color-accent);
    background: var(--color-bg);
  }

  .site-header nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-brand {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-text);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-sans);
  }

  .nav-links a {
    color: var(--color-muted);
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-primary);
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    text-align: center;
    padding: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    font-family: var(--font-sans);
  }

  h1, h2, h3, h4 {
    font-family: var(--font-sans);
    line-height: 1.3;
  }

  h1 { font-size: 2rem; margin-bottom: 1rem; }
  h2 {
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.25rem;
    border-bottom: 2px solid var(--color-accent);
  }
  h3 { font-size: 1.1rem; margin-top: 1rem; margin-bottom: 0.5rem; }

  @media print {
    .site-header, .site-footer { display: none; }
    main { max-width: 100%; padding: 0; }
    .print-banner { display: block !important; }
  }

  .print-banner {
    display: none;
    text-align: center;
    padding: 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    margin-bottom: 1rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }
</style>
